# =============================================================================
# Craft Agents Server — multi-platform Docker image
#
# Build:
#   docker buildx build -f Dockerfile.server -t datapilot-server .
#
# Run (use --user to match host UID/GID for volume permissions):
#   docker run --rm -p 9100:9100 \
#     --user $(id -u):$(id -g) \
#     -e HOME=/home/datapilot \
#     -e DATAPILOT_SERVER_TOKEN=<secret> \
#     datapilot-server
#
# Run with TLS + mounted config:
#   docker run --rm -p 9100:9100 \
#     --user $(id -u):$(id -g) \
#     -e HOME=/home/datapilot \
#     -e DATAPILOT_SERVER_TOKEN=<secret> \
#     -e DATAPILOT_RPC_TLS_CERT=/certs/cert.pem \
#     -e DATAPILOT_RPC_TLS_KEY=/certs/key.pem \
#     -v /path/to/certs:/certs:ro \
#     -v ~/.datapilot:/home/datapilot/.datapilot \
#     datapilot-server
# =============================================================================

FROM oven/bun:1.3-slim

LABEL org.opencontainers.image.source="https://github.com/i-richardwang/datapilot"
LABEL org.opencontainers.image.description="DataPilot Server — headless AI workflow server"
LABEL org.opencontainers.image.licenses="Apache-2.0"

# Install uv (Python package manager) — doc tools use uv to run Python scripts.
# Pinned to the same version used by build-server.ts (scripts/build/common.ts).
COPY --from=ghcr.io/astral-sh/uv:0.10.6 /uv /usr/local/bin/uv

RUN apt-get update && \
    apt-get install -y --no-install-recommends ca-certificates git gosu ripgrep && \
    rm -rf /var/lib/apt/lists/*

# Create non-root user (Claude Code SDK refuses to run as root).
# At runtime, override with --user $(id -u):$(id -g) to match host permissions.
RUN groupadd -r datapilot && \
    useradd -r -g datapilot -m -d /home/datapilot -s /bin/bash datapilot

WORKDIR /app

# Copy dependency manifests first for layer caching.
# bunfig.toml must be present *before* `bun install` runs so the hoisted
# linker setting is honored; otherwise bun falls back to configVersion=1's
# isolated default and Vite can't resolve transitive deps during webui build.
COPY package.json bun.lock bunfig.toml ./
COPY packages/server/package.json packages/server/
COPY packages/server-core/package.json packages/server-core/
COPY packages/shared/package.json packages/shared/
COPY packages/core/package.json packages/core/
COPY packages/session-tools-core/package.json packages/session-tools-core/
COPY packages/session-mcp-server/package.json packages/session-mcp-server/
COPY packages/pi-agent-server/package.json packages/pi-agent-server/
COPY packages/ui/package.json packages/ui/
COPY apps/electron/package.json apps/electron/
COPY apps/cli/package.json apps/cli/
COPY apps/viewer/package.json apps/viewer/
COPY apps/viewer-server/package.json apps/viewer-server/
COPY apps/webui/package.json apps/webui/

# Skip better-sqlite3 native build — Docker runs on Bun which uses built-in bun:sqlite
RUN bun install --frozen-lockfile --ignore-scripts

# Copy source
COPY . .

# Build MCP helper servers (bundled CJS — required by runtime-resolver.ts)
RUN bun build packages/session-mcp-server/src/index.ts \
      --outfile packages/session-mcp-server/dist/index.js --target node --format cjs && \
    bun build packages/pi-agent-server/src/index.ts \
      --outfile packages/pi-agent-server/dist/index.js --target node --format cjs

# Build web UI assets (served by the server on the RPC port)
# Granular feature flags — set to "1" to disable/enable the corresponding feature.
ARG DATAPILOT_DISABLE_OAUTH="1"
ARG DATAPILOT_DISABLE_BROWSER="1"
ARG DATAPILOT_DISABLE_VALIDATION=""
ARG DATAPILOT_DISABLE_TEMPLATES=""
ARG DATAPILOT_LITE_UI="1"
ENV DATAPILOT_DISABLE_OAUTH=$DATAPILOT_DISABLE_OAUTH
ENV DATAPILOT_DISABLE_BROWSER=$DATAPILOT_DISABLE_BROWSER
ENV DATAPILOT_DISABLE_VALIDATION=$DATAPILOT_DISABLE_VALIDATION
ENV DATAPILOT_DISABLE_TEMPLATES=$DATAPILOT_DISABLE_TEMPLATES
ENV DATAPILOT_LITE_UI=$DATAPILOT_LITE_UI
RUN bunx vite build --config apps/webui/vite.config.ts

# Pre-create .datapilot so Docker named volumes inherit the correct permissions.
RUN mkdir -p /home/datapilot/.datapilot

# Make app world-readable so any --user can run it. Home dir is writable for .datapilot.
# Use find to only touch files/dirs missing the read bit — much faster than chmod -R on the
# entire tree (node_modules alone has hundreds of thousands of entries).
RUN find /app -not -perm -o=r -exec chmod o+r {} + && \
    find /app -type d -not -perm -o=x -exec chmod o+x {} + && \
    chmod -R 777 /home/datapilot

# Pre-install Python 3.12 + common data-science packages into a dedicated venv.
# - DATAPILOT_PYTHON: used by transform_data runtime resolver for direct Python access
# - PATH addition: makes python3/pip available in Bash for exploratory analysis
RUN UV_PYTHON_INSTALL_DIR=/opt/uv-python uv python install 3.12 && \
    UV_PYTHON_INSTALL_DIR=/opt/uv-python uv venv /opt/datapilot-py --python 3.12 && \
    uv pip install --python /opt/datapilot-py/bin/python \
      pandas numpy pyarrow polars openpyxl xlsxwriter && \
    chmod -R a+rX /opt/datapilot-py /opt/uv-python

ENV DATAPILOT_RPC_HOST=0.0.0.0
ENV DATAPILOT_RPC_PORT=9100
ENV DATAPILOT_WEBUI_DIR=/app/apps/webui/dist
# Resource resolution — aligned with build-server.ts production entry script
ENV DATAPILOT_BUNDLED_ASSETS_ROOT=/app/apps/electron
ENV DATAPILOT_IS_PACKAGED=false
ENV DATAPILOT_APP_ROOT=/app
ENV DATAPILOT_RESOURCES_PATH=/app/apps/electron/resources
ENV DATAPILOT_PYTHON=/opt/datapilot-py/bin/python
ENV DATAPILOT_UV=/usr/local/bin/uv
ENV DATAPILOT_SCRIPTS=/app/apps/electron/resources/scripts
ENV PATH="/opt/datapilot-py/bin:/app/apps/electron/resources/bin:${PATH}"

EXPOSE 9100

# Smart entrypoint: drop from root to datapilot when the container platform
# (e.g. Zeabur) ignores the Dockerfile USER directive and runs as root.
# Claude Agent SDK refuses --dangerously-skip-permissions under root.
RUN printf '#!/bin/sh\nset -e\nif [ "$(id -u)" = "0" ]; then\n  chown -R datapilot:datapilot /home/datapilot 2>/dev/null || true\n  export HOME=/home/datapilot\n  exec gosu datapilot "$@"\nfi\nexec "$@"\n' > /usr/local/bin/entrypoint.sh && \
    chmod +x /usr/local/bin/entrypoint.sh

# Default to non-root, but entrypoint handles root->datapilot fallback
USER datapilot

# --allow-insecure-bind: safe inside Docker — the container network is isolated;
# external TLS should be handled by a reverse proxy (nginx, Caddy, etc.)
ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
CMD ["bun", "run", "packages/server/src/index.ts", "--allow-insecure-bind"]
