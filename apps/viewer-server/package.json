{
  "name": "@craft-agent/viewer-server",
  "version": "0.8.1",
  "description": "Backend server for hosting shared Craft Agent session transcripts",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "DATAPILOT_DEBUG=true bun run src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@craft-agent/core": "workspace:*",
    "@craft-agent/shared": "workspace:*"
  },
  "optionalDependencies": {
    "@aws-sdk/client-s3": "^3.947.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "@types/node": "^22.0.0"
  }
}
