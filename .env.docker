# Craft Agent Docker Environment
# Copy this file: cp .env.docker .env
# Then edit .env with your values.

# Required — server auth token
# Generate one: docker compose run --rm server --generate-token
CRAFT_SERVER_TOKEN=

# Optional — shorter password for Web UI login (falls back to CRAFT_SERVER_TOKEN)
# CRAFT_WEBUI_PASSWORD=

# Optional — host data directory (default: ~/.craft-agent)
# CRAFT_DATA_DIR=~/.craft-agent

# Optional — viewer public URL
# VIEWER_BASE_URL=http://localhost:9101
